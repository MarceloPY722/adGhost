<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AdGhost" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/ghost_dark</item>
        <item name="android:navigationBarColor">@color/black</item>
    </style>

    <style name="Theme.AdGhost.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ghost_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.AdGhost</item>
    </style>
</resources>
